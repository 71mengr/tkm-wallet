{
  "name": "tkm-wallet",
  "version": "1.0.0",
  "description": "TKM Chain GUI Wallet with RandomX Mining & Rotating Kings",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "node scripts/build.js",
    "dist": "npm run build && electron-builder",
    "dist:windows": "npm run build && electron-builder --win",
    "dist:linux": "npm run build && electron-builder --linux",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:all": "npm run build && electron-builder -mwl"
  },
  "author": "TKM Chain",
  "license": "MIT",
  "dependencies": {
    "electron": "^28.0.0",
    "web3": "^1.10.0",
    "electron-store": "^8.1.0",
    "axios": "^1.6.0",
    "node-fetch": "^3.3.0"
  },
  "devDependencies": {
    "electron-builder": "^24.6.4",
    "electron-rebuild": "^3.2.9"
  },
  "build": {
    "appId": "com.tkmchain.wallet",
    "productName": "TKM Wallet",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "main.js",
      "preload.js",
      "node_modules/**/*"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "build/icon.ico"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb",
        "rpm"
      ],
      "icon": "build/icon.png",
      "category": "Finance"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "build/icon.icns",
      "category": "public.app-category.finance"
    }
  }
}
